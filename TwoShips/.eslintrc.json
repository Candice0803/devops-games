{
  "env": {
    "browser": true,
    "es2021": true,
    "node": true
  },
  "extends": "google",
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "rules": {
    "camelcase": "off",
    "no-var": "off",
    "max-len": "off",
    "no-unused-vars": "off",
    "require-jsdoc": "off",
    "linebreak-style": 0,
    "indent": "off",
    "comma-dangle": "off",
    "quotes": "off",
    "semi": "off",
    "object-curly-spacing": "off",
    "spaced-comment": "off",
    "no-multi-spaces": "off"
  }
}